peso = float(input("Ingrese el peso en kg: "))
altura = float(input("Ingrese la altura en metros: "))

imc = peso / (altura ** 2)

print("IMC:", round(imc, 2))

if imc < 18.5:
    print("Bajo peso")

elif imc >= 18.5 and imc <= 24.9:
    print("Normal")

elif imc >= 25 and imc <= 29.9:
    print("Sobrepeso")

else:
    print("Obesidad")
